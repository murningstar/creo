{
    "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
    "productName": "creo",
    "version": "0.1.0",
    "identifier": "creo",
    "build": {
        "frontendDist": "../dist",
        "devUrl": "http://localhost:4730",
        "beforeDevCommand": "pnpm dev",
        "beforeBuildCommand": "pnpm generate"
    },
    "app": {
        "windows": [
            {
                "label": "main",
                "title": "Creo",
                "width": 800,
                "height": 600,
                "minWidth": 600,
                "minHeight": 400,
                "resizable": true,
                "fullscreen": false
            },
            {
                "label": "overlay",
                "url": "/overlay",
                "title": "Creo Indicator",
                "width": 96,
                "height": 96,
                "transparent": true,
                "decorations": false,
                "alwaysOnTop": true,
                "shadow": false,
                "resizable": false,
                "closable": false,
                "visible": false,
                "focus": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
    }
}
